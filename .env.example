# ==========================================
# Bot_HH_Habr — Переменные окружения
# Скопировать в .env и заполнить значения
# ==========================================

# --- Supabase ---
SUPABASE_URL=https://supabase.assisthelp.ru
SUPABASE_SERVICE_KEY=eyJ...

# --- Telegram ---
TELEGRAM_BOT_TOKEN=1234567890:AAF...
TELEGRAM_CHANNEL_ID=-1001234567890

# --- Google Sheets ---
# ID таблицы из URL: docs.google.com/spreadsheets/d/{GOOGLE_SHEETS_ID}/edit
GOOGLE_SHEETS_ID=1BxiMVs0XRA5nFMdKvBdBZjgmUUqptlbs74OgVE2upms
# Путь к JSON-файлу сервисного аккаунта Google
GOOGLE_SERVICE_ACCOUNT_JSON=./google-service-account.json
# Имя листа в таблице
GOOGLE_SHEET_NAME_QUALIFIED=Подходящие
GOOGLE_SHEET_NAME_FILTERED=Отфильтрованные
GOOGLE_SHEET_NAME_RANKING=Рейтинг

# --- Рейтинг кандидатов ---
# С какой даты считать кандидатов (ISO). По умолчанию — 20 апреля 2026
RANKING_SINCE=2026-04-20T00:00:00Z
# Максимум строк в листе «Рейтинг» Google Sheets
RANKING_LIMIT=50
# Сколько кандидатов показывать в pinned-сообщении Telegram
RANKING_TELEGRAM_TOP=15

# --- Mini App (HTTP API) ---
# Express-сервер для Mini App. Запускается отдельным процессом PM2 (ecosystem.config.cjs).
API_PORT=3001
API_HOST=0.0.0.0
# Публичный HTTPS URL Mini App (Cloudflare Pages). Используется в кнопках Telegram.
WEBAPP_URL=https://hr-bot.pages.dev
# Whitelist Telegram user_id, через запятую. Только этим пользователям API будет отдавать данные.
WEBAPP_ALLOWED_USER_IDS=12345678
# Разрешённые CORS-источники, через запятую. Обычно: https://hr-bot.pages.dev
WEBAPP_ALLOWED_ORIGINS=https://hr-bot.pages.dev
# Только для локальной разработки! Отключает проверку initData. В проде НЕ ставить.
# API_AUTH_DISABLED=0

# --- Хабр Карьера ---
# Полная строка Cookie из DevTools (F12 → Network → любой запрос career.habr.com → заголовок Cookie)
HABR_COOKIE=_ga=GA1...; _habr_session=...; ...
# ID вакансий через запятую. Берётся из URL: career.habr.com/vacancies/{ID}
# API: GET /api/frontend/vacancies/{ID}/responses?page={N}
HABR_VACANCY_IDS=1000164921
# Страниц за цикл (25 откликов/страница). При 625 откликах — хватит 3-5 для новых
HABR_PAGES_TO_CHECK=5

# --- HeadHunter (заполнить на Фазе 2) ---
HH_CLIENT_ID=
HH_CLIENT_SECRET=
HH_ACCESS_TOKEN=
HH_REFRESH_TOKEN=
HH_EMPLOYER_ID=

# --- Настройки воркера ---
# Интервал опроса в миллисекундах (300000 = 5 минут)
POLL_INTERVAL_MS=300000
# Задержка между запросами резюме внутри цикла (мс), чтобы не спамить сервер
REQUEST_DELAY_MS=1500
# Уровень логирования: error | warn | info | debug
LOG_LEVEL=info
NODE_ENV=production
